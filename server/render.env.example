# Render.com Mühit Dəyişənləri Örnəyi
# Bu dosyanı kopiyalayaraq Render.com Dashboard'da environment variables bölməsinə ekləyin

# Node Mühiti
NODE_ENV=production

# Server Konfiqurasiyası
PORT=10000

# JWT Məxfi Açarı (Təhlükəsizlik üçün dəyişilməlidir)
JWT_SECRET=your-super-secret-key-change-in-production

# CORS İcazələri (vergüllə ayrılmış domain siyahısı)
ALLOWED_ORIGINS=https://kinosu.azdroid.tech,https://kinosu-backend.onrender.com

# Frontend URL (Şifrə sıfırlama emailləri üçün)
FRONTEND_URL=https://kinosu-backend.onrender.com

# Supabase Konfiqurasiyası
SUPABASE_URL=https://your-supabase-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-key

# OMDb API Açarı (Film məlumatları üçün)
VITE_OMDB_API_KEY=your-omdb-api-key

# SMTP Konfiqurasiyası (Email göndərmə)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-email-app-password 